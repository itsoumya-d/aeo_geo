# Cognition AI Visibility Engine - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Required for authentication)
# Get these from your Supabase project settings: https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini API Key (Required for AI analysis)
# Get this from Google AI Studio: https://ai.google.dev/
API_KEY=your_gemini_api_key

# Stripe Configuration (Required for billing)
# Get these from Stripe Dashboard: https://dashboard.stripe.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (Create products in Stripe Dashboard → Products)
# Each plan needs a recurring price with monthly billing
VITE_STRIPE_STARTER_PRICE_ID=price_xxx
VITE_STRIPE_PRO_PRICE_ID=price_xxx
VITE_STRIPE_AGENCY_PRICE_ID=price_xxx

# Backend Secrets (Set via `supabase secrets set`)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Monitoring & Analytics (Optional but recommended)
# Sentry - Error tracking: https://sentry.io/
VITE_SENTRY_DSN=

# Mixpanel - Product analytics: https://mixpanel.com/
VITE_MIXPANEL_TOKEN=
