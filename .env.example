# Cognition AI Visibility Engine - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Required for authentication)
# Get these from your Supabase project settings: https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Provider Keys (Server-side only)
# Configure these via Supabase secrets (not Vite env vars).
# Example:
#   supabase secrets set GEMINI_API_KEY=... OPENAI_API_KEY=... ANTHROPIC_API_KEY=... PERPLEXITY_API_KEY=...
# Additional Platform Keys:
#   supabase secrets set GOOGLE_SEARCH_API_KEY=... BING_API_KEY=... META_AI_API_KEY=... XAI_API_KEY=...

# Paddle Configuration (Required for billing)
# Get these from Paddle Dashboard: https://vendors.paddle.com
VITE_PADDLE_CLIENT_TOKEN=test_xxx
VITE_PADDLE_ENVIRONMENT=sandbox

# Paddle Price IDs (Create products in Paddle Dashboard → Catalog)
VITE_PADDLE_STARTER_PRICE_ID=pri_xxx
VITE_PADDLE_PRO_PRICE_ID=pri_xxx
VITE_PADDLE_AGENCY_PRICE_ID=pri_xxx

# Paddle one-time top-up Price IDs
VITE_PADDLE_TOPUP_10_PRICE_ID=pri_xxx
VITE_PADDLE_TOPUP_50_PRICE_ID=pri_xxx
VITE_PADDLE_TOPUP_150_PRICE_ID=pri_xxx

# Backend Secrets (Set via `supabase secrets set`)
# PADDLE_API_KEY=xxx
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxx
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxx
# GOOGLE_OAUTH_REDIRECT_URI=https://your-project.supabase.co/functions/v1/gsc-sync?action=callback

# Monitoring & Analytics (Optional but recommended)
# Sentry - Error tracking: https://sentry.io/
VITE_SENTRY_DSN=

# Mixpanel - Product analytics: https://mixpanel.com/
VITE_MIXPANEL_TOKEN=

# App Version (displayed in sidebar)
VITE_APP_VERSION=1.0.0
